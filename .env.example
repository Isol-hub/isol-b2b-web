# WebSocket backend URL (no trailing slash)
VITE_WSS_URL=wss://wss.isol.live

# Cloudflare Pages Functions env vars (set in CF dashboard, NOT committed)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# JWT_SECRET=your-32-char-secret-here
# CF_KV_OTP=<bound KV namespace - set in wrangler.toml for dev>

# Optional: restrict email domains per workspace (comma-separated, or * for any)
# ALLOWED_EMAIL_DOMAINS=acme.com,partner.com

# Optional: Sentry DSN for frontend error monitoring (leave unset to disable Sentry in dev)
# VITE_SENTRY_DSN=https://xxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
